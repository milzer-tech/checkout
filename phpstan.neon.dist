includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 7
    paths:
        - src

    excludePaths:
        # SOAP/XSD-mapped Spatie Data objects (generated-style); typed at integration boundaries.
        - src/Integrations/Ergo/Dtos
        - src/Integrations/Ergo/Casts

    reportUnmatchedIgnoredErrors: true
    treatPhpDocTypesAsCertain: false


