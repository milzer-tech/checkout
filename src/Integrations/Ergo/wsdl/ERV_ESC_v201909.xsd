		</xsd:annotation>
		<xsd:complexType>
			<xsd:sequence>
				<xsd:element name="Requestor" type="common:RequestorType">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">This holds details regarding the requestor.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="RebookPolicyNumber" type="common:StringLength1to32" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">To rebook a policy, the policy number of the origin contract has to be sent in this element.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="PreContractualInformationID" type="common:StringLength1to50" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">ID reference to the pre-contractual information</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="CoveredTravelers" type="common:CoveredTravelersType">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Container for information about the travelers requesting coverage by the insurance plan.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="QuoteIDRef" type="common:StringLength1to36" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Reference on an insurance offer (QuoteRS).</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="CoveredTrip" type="common:TripType">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Container for any information about the trip(s) for which the traveler(s) are requesting coverage.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="InsuranceCustomer" type="common:InsuranceCustomerType" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Contains data on the insurance customer</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="BookServices" type="common:RequestServicesType">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Requested service</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="AdditionalPolicyInfo" type="common:StringLength1to60" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Additional policy information, e.g. bookkeeping note. This information will be printed on the policy.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="ExternalReferenceId" type="common:StringLength1to100" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">External reference identifier of the ESC service user, e.g. PNR number. This information will not be printed on the policy.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="EmailPolicy" type="common:EmailsType" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">If this element contains email addresses, then the policy will be sent to these addresses. If there is no EmailPolicy element, then no emails will be sent.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="Insurance" type="common:InsuranceCritsType" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Additional insurance information</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="Extensions" type="common:ExtensionsType" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>additional fields as key-value pairs , example: to provide vehicle details as a key-value pair in extension, use key as VehicleDetails and provide value in format BRAND|MODEL|LICENCEPLATE say Renault|Clio|MNI-1234 </xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:sequence>
			<xsd:attributeGroup ref="common:PayloadStdAttributes"/>
		</xsd:complexType>
	</xsd:element>
