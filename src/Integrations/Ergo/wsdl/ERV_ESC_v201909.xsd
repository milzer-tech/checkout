	<xsd:import namespace="http://www.erv.de/eSoap/2019/09/common" schemaLocation="ERV_ESC_v201909_CommonTypes.xsd"/>
	<xsd:element name="ERV_InsuranceCancelRQ">
		<xsd:annotation>
			<xsd:documentation xml:lang="en">ERV cancellation and partial cancellation request</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:sequence>
				<xsd:element name="Requestor" type="common:RequestorType">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">This holds details regarding the requestor.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="PolicyNumber" type="common:StringLength1to32">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Policy number to cancel. If the request does not contain: CancelTravelers, CancelServices and CancelAllocations, than it's a total cancellation.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="CancelTravelers" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Reference on the insured persons, which have to be cancelled.</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="CancelTraveler" type="common:CancelTravelerType" maxOccurs="unbounded">
								<xsd:annotation>
									<xsd:documentation xml:lang="en">Insured person (CoveredTraveler - ID) which has to be cancelled.</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="CancelServices" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Reference on the services (Service - ID) which have to be cancelled.</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="CancelService" type="common:CancelServiceType" maxOccurs="unbounded">
								<xsd:annotation>
									<xsd:documentation xml:lang="en">Service which has to be cancelled.</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="CancelAllocations" minOccurs="0">
					<xsd:annotation/>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="CancelAllocation" type="common:CancelAllocationType" maxOccurs="unbounded">
								<xsd:annotation/>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="Verification" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">Verification data of the origin policy</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="CoveredTravelers" type="common:CoveredTravelersType" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation xml:lang="en">Covered traveler data of the origin policy.</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="Services" type="common:ServicesType" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation xml:lang="en">Service data of the origin policy.</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="EmailPolicy" type="common:EmailsType" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation xml:lang="en">If the request contains this element, then the new policy (partial cancellation) will be sent per email: 1. If there are AdditionalEmail-elements, then the policy will be sent to these email addresses. 2. If there is no AdditionalEmail-Element, then the policy will be sent to the email address of the insurance customer.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:sequence>
			<xsd:attributeGroup ref="common:PayloadStdAttributes"/>
		</xsd:complexType>
	</xsd:element>
