<?xml version="1.0" encoding="UTF-8"?>
<!-- Mit XMLSpy v2013 rel. 2 sp1 (x64) (http://www.altova.com) von Andrea Steiger (ITERGO Lizenzmanagement) bearbeitet -->
<xs:schema xmlns:common="http://www.erv.de/eSoap/2019/09/common" xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.erv.de/eSoap/2019/09/common" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xs:complexType name="ProductComponentsType">
		<xs:annotation/>
		<xs:sequence>
			<xs:element name="ProductComponent" type="common:ProductComponentType" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">Product Component</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="creditcardHolderType">
		<xs:sequence>
			<xs:element name="prename" type="common:StringLength0to30">
				<xs:annotation>
					<xs:documentation>cardHolder prename [Vorname Kreditkarteninhaber]</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="surname" type="common:StringLength1to60">
				<xs:annotation>
					<xs:documentation>cardHolder surname [Name Kreditkarteninhaber]</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="streetAndNumber" type="common:StringLength1to50">
				<xs:annotation>
					<xs:documentation>street [Strasse]</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="zipCode" type="common:StringLength1to7">
				<xs:annotation>
					<xs:documentation>zip code [PLZ]</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="city" type="common:StringLength1to30">
				<xs:annotation>
					<xs:documentation>city [Stadt]</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="countryCode" type="common:AlphaStringLength2">
				<xs:annotation>
					<xs:documentation>country [Land 2-stellig]</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="email" type="common:StringLength1to100" minOccurs="0">
				<xs:annotation>
					<xs:documentation>email address [eMail Adresse]</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ProductComponentType">
			<xs:annotation>
				<xs:documentation xml:lang="en">ProductComponent attributes</xs:documentation>
			</xs:annotation>
			<xs:attribute name="Ordering" type="xs:integer" use="required">
				<xs:annotation>
					<xs:documentation xml:lang="en">Sort sequence</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="Name" type="common:StringLength1to255" use="required">
				<xs:annotation>
					<xs:documentation xml:lang="en">Product Component Name</xs:documentation>
				</xs:annotation>
			</xs:attribute>
	</xs:complexType>
	<xs:complexType name="AddressType">
		<xs:sequence>
			<xs:element name="StreetAndNr" type="common:StringLength1to100">
				<xs:annotation>
					<xs:documentation xml:lang="en">Street name, street number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CityName" type="common:StringLength1to30">
				<xs:annotation>
					<xs:documentation xml:lang="en">City</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PostalCode" type="common:StringLength1to9">
				<xs:annotation>
					<xs:documentation xml:lang="en">Post Office Code number.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Country" type="common:CountryCodeISO3166">
				<xs:annotation>
					<xs:documentation xml:lang="en">ISO 3166 country code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtraAddressLine" type="common:StringLength1to30" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Additional address information</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AvailablePlans">
		<xs:annotation>
			<xs:documentation xml:lang="en">Available insurance plans</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="AvailablePlan" type="common:AvailablePlanType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">Available insurance plan</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AvailablePlanType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Information container for an insurance plan</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PlanDetail">
				<xs:annotation>
					<xs:documentation xml:lang="en">Insurance plan informations</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Title" type="common:StringLength1to255"/>
						<xs:element name="DescriptionURL" type="common:DescriptionURLType" minOccurs="0" maxOccurs="unbounded"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Quote" type="common:QuoteType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">The response will only contain this element, if the AutoQuote-attribute in the insurance plan request is 'true'</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="PlanCode" type="common:StringLength1to32" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Unique insurance plan identifier</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="Ordering" type="xs:integer" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Sort sequence</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="BankAcctType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Customer bank accounts for payments</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:sequence>
				<xs:element name="BankID" type="xs:string" minOccurs="0">
					<xs:annotation>
						<xs:documentation xml:lang="en">Bank code or BIC</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="BankAcctNumber" type="xs:string">
					<xs:annotation>
						<xs:documentation xml:lang="en">Identifier for the account assigned by the bank. Account number or IBAN</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="DifferingAccountHolder" minOccurs="0">
					<xs:annotation>
						<xs:documentation xml:lang="en">Differing (from insurance customer) bank account holder.</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="NamePrefix" minOccurs="0">
								<xs:annotation>
									<xs:documentation xml:lang="en">Salutation</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:enumeration value="B">
											<xs:annotation>
												<xs:documentation xml:lang="en">Baby</xs:documentation>
											</xs:annotation>
										</xs:enumeration>
										<xs:enumeration value="I">
											<xs:annotation>
												<xs:documentation xml:lang="en">Infant</xs:documentation>
											</xs:annotation>
										</xs:enumeration>
										<xs:enumeration value="K">
											<xs:annotation>
												<xs:documentation xml:lang="en">Child</xs:documentation>
											</xs:annotation>
										</xs:enumeration>
										<xs:enumeration value="H">
											<xs:annotation>
												<xs:documentation xml:lang="en">Mr.</xs:documentation>
											</xs:annotation>
										</xs:enumeration>
										<xs:enumeration value="D">
											<xs:annotation>
												<xs:documentation xml:lang="en">Mrs.</xs:documentation>
											</xs:annotation>
										</xs:enumeration>
										<xs:enumeration value="G">
											<xs:annotation>
												<xs:documentation xml:lang="en">Group</xs:documentation>
											</xs:annotation>
										</xs:enumeration>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="NameTitle" type="xs:string" minOccurs="0">
								<xs:annotation>
									<xs:documentation xml:lang="en">Degree or honors (e.g., Ph.D., M.D.) </xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="GivenName" type="xs:string">
								<xs:annotation>
									<xs:documentation xml:lang="en">Given name, first name</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="Surname" type="xs:string">
								<xs:annotation>
									<xs:documentation xml:lang="en">Family name, last name</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="Email" type="xs:string">
								<xs:annotation>
									<xs:documentation xml:lang="en">Email address</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="Address">
								<xs:complexType>
									<xs:sequence>
										<xs:element name="StreetAndNr" type="xs:string">
											<xs:annotation>
												<xs:documentation xml:lang="en">Street name, street number</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="CityName" type="xs:string">
											<xs:annotation>
												<xs:documentation xml:lang="en">City</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="PostalCode" type="xs:string">
											<xs:annotation>
												<xs:documentation xml:lang="en">Post Office Code number.</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="Country" type="common:CountryCodeISO3166">
											<xs:annotation>
												<xs:documentation xml:lang="en">ISO 3166 country code</xs:documentation>
											</xs:annotation>
										</xs:element>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
			<xs:element name="bankSecureHandleID" type="common:secureHandleIDType">
				<xs:annotation>
					<xs:documentation xml:lang="en">pay with bank secureHandle ID</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="CancelAllocationType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Allocation which has to be cancelled.</xs:documentation>
		</xs:annotation>
		<xs:attribute name="AllocationIDRef" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Allocation reference</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="CancelServiceType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Service which has to be cancelled.</xs:documentation>
		</xs:annotation>
		<xs:attribute name="ServiceIDRef" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Service reference</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="CancelTravelerType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Covered person which has to be cancelled</xs:documentation>
		</xs:annotation>
		<xs:attribute name="TravelerIDRef" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Covered person reference</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="CoveredTravelersType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Container for covered travelers</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="CoveredTraveler" type="common:CoveredTravelerType" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CoveredTravelerType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Contains identifying information as well as coverage requirements and journey information for each individual requesting coverage by the insurance plan.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="CoveredPerson" type="common:PersonType">
				<xs:annotation>
					<xs:documentation xml:lang="en">Name data of the covered person</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="IndCoverageReqs" type="common:IndCoverageReqsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Container for individual coverage details.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Extensions" type="common:ExtensionsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>probably additional fields</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="ID" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Unique covered person identifier</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="CoveredTripSearchCritType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Search criterions based on covered trip data</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartDate" type="common:PeriodType" minOccurs="0">
				<xs:annotation/>
			</xs:element>
			<xs:element name="EndDate" type="common:PeriodType" minOccurs="0">
				<xs:annotation/>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DescriptionURLType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Container for description information</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:anyURI">
				<xs:attribute name="Type" type="common:StringLength1to16" use="required"/>
				<xs:attribute name="DefaultInd" type="xs:boolean" use="required"/>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="DestinationType">
		<xs:choice>
			<xs:element name="Country" type="common:CountryCodeISO3166" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">ISO3166 country code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Airport" type="common:AirportCodeIATA" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">IATA airport code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Region" type="xs:string">
				<xs:annotation>
					<xs:documentation xml:lang="en">region</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="EmailsType">
		<xs:sequence>
			<xs:element name="AdditionalEmail" type="common:StringLength1to255" minOccurs="0" maxOccurs="2">
				<xs:annotation>
					<xs:documentation xml:lang="en">Email address</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="EPaymentCardType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Identification about a specific epayment credit card</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="EPaymentProvider" type="common:EPaymentProviderType">
				<xs:annotation>
					<xs:documentation xml:lang="en">payment service provider code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CardType" type="common:CardTypeType">
				<xs:annotation>
					<xs:documentation xml:lang="en">Indicates the type of credit card.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TransactionID" type="xs:string">
				<xs:annotation>
					<xs:documentation xml:lang="en">Unique payment transaction ID</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ReferenceID" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Unique merchant order reference id/Shopping basket id/Shopping cart id</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ErrorsType">
		<xs:sequence>
			<xs:element name="Error" type="common:ErrorType" maxOccurs="99"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ErrorType">
		<xs:sequence>
			<xs:element name="ErrorCode" type="xs:string">
				<xs:annotation>
					<xs:documentation xml:lang="en">Unique eror code - format = XXX-XXXXX. There are 3 different error types. Error codes starting with "ERV-" are business errors and should be forwarded to the end user (travel agent). Error codes starting with "SYS-" are system errors and should not be forwarded to the end user. ErrorCodes starting with "FAT-" are fatal errors.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ErrorMessage" type="xs:string">
				<xs:annotation>
					<xs:documentation xml:lang="en">Error message.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="language" type="common:LanguageCodeISO639">
			<xs:annotation>
				<xs:documentation xml:lang="en">Language of the error message.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="type" type="xs:string"/>
	</xs:complexType>
	<xs:complexType name="ERVAgencyType">
		<xs:sequence>
			<xs:element name="Hagtnr" type="xs:string">
				<xs:annotation>
					<xs:documentation xml:lang="en">ERV hagtnr</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Nagtnr" type="xs:string">
				<xs:annotation>
					<xs:documentation xml:lang="en">ERV nagtnr</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:simpleType name="PayPageHandleIDType">
		<xs:annotation>
			<xs:documentation>type for ERV payPagehandle ID</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:maxLength value="128"/>
			<xs:minLength value="0"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="ExtensionsType">
		<xs:sequence>
			<xs:element name="Extension" type="common:ExtensionType" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ExtensionType">
		<xs:sequence>
			<xs:element name="Key" type="common:StringLength1to30">
				<xs:annotation>
					<xs:documentation xml:lang="en">Key</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Value" type="common:StringLength1to250">
				<xs:annotation>
					<xs:documentation xml:lang="en">Value</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="IndCoverageReqsType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Contains identifying information as well as coverage requirements and journey information for each individual.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="IndTripCost" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Individual trip price.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:attributeGroup ref="common:CurrencyAmountGroup"/>
				</xs:complexType>
			</xs:element>
			<xs:element name="FlightAccidentAmount" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Individual flight accident coverage sum.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:attributeGroup ref="common:CurrencyAmountGroup"/>
				</xs:complexType>
			</xs:element>
			<xs:element name="TripAccidentAmount" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Individual trip accident coverage sum.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:attributeGroup ref="common:CurrencyAmountGroup"/>
				</xs:complexType>
			</xs:element>
			<xs:element name="CoveredLuggage" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Individual luggage coverage sum.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:attributeGroup ref="common:CurrencyAmountGroup"/>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InsuranceCritsType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Additional insurance information</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="TariffCategory" type="common:AlphaLength2" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Category of the insured item. Refer to Appendix A3</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TourOperator" type="common:StringLength1to40" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Touroperator</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InsuranceCustomerType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Contains data on the insurance customer.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PersonName" type="common:CustomerNameType">
				<xs:annotation>
					<xs:documentation xml:lang="en">Name data of the insurance customer</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Email" type="common:StringLength1to255" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Email address</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Address" type="common:AddressType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Address data of the insurance customer</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PaymentForm" type="common:PaymentFormType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Form of payment</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Telephone" type="common:StringLength1to25" minOccurs="0" maxOccurs="2">
				<xs:annotation>
					<xs:documentation xml:lang="en">Phone number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Mobile" type="common:StringLength1to25" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Mobile number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="common:StringLength1to25" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Fax number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Birthdate" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Birthdate</xs:documentation>
				</xs:annotation>
