							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="LT">
							<xs:annotation>
								<xs:documentation xml:lang="en">long term insurance</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
