	<xs:complexType name="PSD2ParameterType">
		<xs:annotation>
			<xs:documentation>type for psd2 parameter</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="cavv">
				<xs:annotation>
					<xs:documentation>Cardholder Authentication Verification Value</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:minLength value="1"/>
						<xs:maxLength value="50"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="eci" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Electronic Commerce Indicator</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:length value="2"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="threeDSVersion">
				<xs:annotation>
					<xs:documentation>3D Secure Version 1.0.2,2.1.0 or 2.2.0</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:length value="5"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="threeDSTransactionId"> 
				<xs:annotation> 
					<xs:documentation>TransaktionsId 3D Secure 1.0 -xid- or 2.0 -dstid-</xs:documentation> 
				</xs:annotation> 
				<xs:simpleType> 
					<xs:restriction base="xs:string"> 
						<xs:minLength value="1"/> 
						<xs:maxLength value="50"/> 
					</xs:restriction> 
				</xs:simpleType> 
			</xs:element>
			<xs:element name="psd2Extensions" type="common:ExtensionsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>probably additional fields for PSD2 Authorization [mögliche weitere Felder für PSD2]</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
